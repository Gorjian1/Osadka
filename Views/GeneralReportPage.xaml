<UserControl
    x:Class="Osadka.Views.GeneralReportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:conv="clr-namespace:Osadka.Converters"
    mc:Ignorable="d"
    d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <ToolBar VerticalAlignment="Top" Background="#F9FBFD">
            <Button Content="🔢 Рассчитать"
                    Command="{Binding CalculateCommand}"
                    ToolTip="Пересчитать отчёт"/>
            <Separator/>
            <Button Content="📤 Экспорт (общий)"
                    Command="{Binding ExportCommand}"
                    ToolTip="Сохранить общий отчёт в Excel"/>
            <Separator/>
            <Button Content="Открыть шаблон"
                    Command="{Binding OpenTemplate}"
                    ToolTip="Сохранить общий отчёт в Excel"/>
        </ToolBar>

        <ScrollViewer Margin="0,40,0,0">
            <StackPanel Margin="16">

                <TextBlock Text="Общая осадка , мм"
                           FontWeight="Bold" Margin="0,0,0,4"/>
                <UniformGrid Columns="3" Margin="0,0,0,12">
                    <TextBlock Text="Максимальная:"/>
                    <TextBlock Text="{Binding Report.MaxTotal.Value, StringFormat={}{0:F1}}"/>
                    <TextBlock Text="{Binding Report.MaxTotal.Ids, Converter={StaticResource Join}}"/>

                    <TextBlock Text="Минимальная:"/>
                    <TextBlock Text="{Binding Report.MinTotal.Value, StringFormat={}{0:F1}}"/>
                    <TextBlock Text="{Binding Report.MinTotal.Ids, Converter={StaticResource Join}}"/>

                    <TextBlock Text="Среднее значение:"/>
                    <TextBlock Text="{Binding Report.AvgTotal, StringFormat={}{0:F1}}"
                               Grid.ColumnSpan="2"/>
                </UniformGrid>

                <TextBlock Text="Осадка за цикл , мм"
                           FontWeight="Bold" Margin="0,0,0,4"/>
                <UniformGrid Columns="3" Margin="0,0,0,12">
                    <TextBlock Text="Максимальная:"/>
                    <TextBlock Text="{Binding Report.MaxSettl.Value, StringFormat={}{0:F1}}"/>
                    <TextBlock Text="{Binding Report.MaxSettl.Ids, Converter={StaticResource Join}}"/>

                    <TextBlock Text="Минимальная:"/>
                    <TextBlock Text="{Binding Report.MinSettl.Value, StringFormat={}{0:F1}}"/>
                    <TextBlock Text="{Binding Report.MinSettl.Ids, Converter={StaticResource Join}}"/>

                    <TextBlock Text="Среднее значение:"/>
                    <TextBlock Text="{Binding Report.AvgSettl, StringFormat={}{0:F1}}"
                               Grid.ColumnSpan="2"/>
                </UniformGrid>

                <TextBlock Text="Значения отметок" FontWeight="Bold" Margin="0,8,0,2"/>
                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Нет доступа:"/>
                    <TextBlock Text="{Binding Report.NoAccessIds, Converter={StaticResource Join}}"/>

                    <TextBlock Text="Уничтожены:" Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding Report.DestroyedIds, Converter={StaticResource Join}}"/>

                    <TextBlock Text="Новые:" Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding Report.NewIds, Converter={StaticResource Join}}"/>
                </StackPanel>

                <TextBlock Text="Точки с превышением" FontWeight="Bold" Margin="0,8,0,2"/>
                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Превышения максимальной осадки по СП:" FontWeight="Bold" Margin="0,8,0,0"/>
                    <TextBlock Text="{Binding ExceedTotalSpDisplay}" TextWrapping="Wrap"/>

                    <TextBlock Text="Превышения максимальной осадки по расчётам:" FontWeight="Bold" Margin="0,8,0,0"/>
                    <TextBlock Text="{Binding ExceedTotalCalcDisplay}" TextWrapping="Wrap"/>
                </StackPanel>

                <TextBlock Text="Превышения относительной осадки по СП:" FontWeight="Bold"/>
                <TextBlock Text="{Binding ExceedRelSpDisplay}" TextWrapping="Wrap"/>

                <TextBlock Text="Превышения относительной осадки по расчётам:" FontWeight="Bold" Margin="0,8,0,0"/>
                <TextBlock Text="{Binding ExceedRelCalcDisplay}" TextWrapping="Wrap" Margin="0,8,0,0"/>


            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
