<UserControl x:Class="Osadka.Views.GeneralReportPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">

    <!-- Локальные стили, чтобы не было ошибок разрешения ресурсов -->
    <UserControl.Resources>
        <!-- Карточка -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- Заголовок секции -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Подпись метрики -->
        <Style x:Key="MetricLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#444"/>
        </Style>

        <!-- Значение метрики -->
        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,2,0,6"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка: текущий цикл и предельные значения -->
        <WrapPanel Grid.Row="0" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" Margin="0,0,16,6" VerticalAlignment="Center">
                <TextBlock Text="Цикл:" VerticalAlignment="Center" Style="{StaticResource SectionTitle}" />
                <TextBlock Text="{Binding DataContext.RawVM.SelectedCycleHeader, RelativeSource={RelativeSource AncestorType=Window}}"
                   VerticalAlignment="Center" Margin="6,0,0,0"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,16,6" VerticalAlignment="Center">
                <TextBlock Text="Предел СП (вектор):" VerticalAlignment="Center"/>
                <TextBox Width="80"
                 Margin="6,0,0,0"
                 Text="{Binding DataContext.RawVM.Header.MaxNomen, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,16,6" VerticalAlignment="Center">
                <TextBlock Text="Предел расчётный (вектор):" VerticalAlignment="Center"/>
                <TextBox Width="80"
                 Margin="6,0,0,0"
                 Text="{Binding DataContext.RawVM.Header.MaxCalculated, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,16,6" VerticalAlignment="Center">
                <TextBlock Text="Предел СП (относит.):" VerticalAlignment="Center"/>
                <TextBox Width="80"
                 Margin="6,0,0,0"
                 Text="{Binding DataContext.RawVM.Header.RelNomen, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,16,6" VerticalAlignment="Center">
                <TextBlock Text="Предел расчётный (относит.):" VerticalAlignment="Center"/>
                <TextBox Width="80"
                 Margin="6,0,0,0"
                 Text="{Binding DataContext.RawVM.Header.RelCalculated, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </WrapPanel>

        <!-- Контент: карточки экстремумов -->
        <UniformGrid Grid.Row="1" Rows="2" Columns="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0,4,0,0">

            <!-- Вектор -->
            <Border Style="{StaticResource Card}" Margin="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Вектор смещения, мм" Style="{StaticResource SectionTitle}" Grid.Row="0"/>

                    <Grid Grid.Row="1" Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Максимум" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Text="{Binding Report.MaxVector.Value, StringFormat=F2}" Style="{StaticResource MetricValue}"/>
                            <ItemsControl ItemsSource="{Binding Report.MaxVector.Ids}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="Минимум" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Text="{Binding Report.MinVector.Value, StringFormat=F2}" Style="{StaticResource MetricValue}"/>
                            <ItemsControl ItemsSource="{Binding Report.MinVector.Ids}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="2" Margin="0,8,0,0">
                        <TextBlock Text="Превышения (СП):" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding ExceedTotalSpDisplay}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                        <TextBlock Text="Превышения (расч.):" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding ExceedTotalCalcDisplay}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ΔX -->
            <Border Style="{StaticResource Card}" Margin="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="ΔX, мм" Style="{StaticResource SectionTitle}" Grid.Row="0"/>
                    <Grid Grid.Row="1" Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Максимум" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Text="{Binding Report.MaxDx.Value, StringFormat=F2}" Style="{StaticResource MetricValue}"/>
                            <ItemsControl ItemsSource="{Binding Report.MaxDx.Ids}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="Минимум" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Text="{Binding Report.MinDx.Value, StringFormat=F2}" Style="{StaticResource MetricValue}"/>
                            <ItemsControl ItemsSource="{Binding Report.MinDx.Ids}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- ΔY -->
            <Border Style="{StaticResource Card}" Margin="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="ΔY, мм" Style="{StaticResource SectionTitle}" Grid.Row="0"/>
                    <Grid Grid.Row="1" Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Максимум" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Text="{Binding Report.MaxDy.Value, StringFormat=F2}" Style="{StaticResource MetricValue}"/>
                            <ItemsControl ItemsSource="{Binding Report.MaxDy.Ids}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="Минимум" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Text="{Binding Report.MinDy.Value, StringFormat=F2}" Style="{StaticResource MetricValue}"/>
                            <ItemsControl ItemsSource="{Binding Report.MinDy.Ids}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- ΔH (только когда есть H) -->
            <Border Margin="6">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource Card}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Report.MaxDh}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="ΔH, мм" Style="{StaticResource SectionTitle}" Grid.Row="0"/>
                    <Grid Grid.Row="1" Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Максимум" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Text="{Binding Report.MaxDh.Value, StringFormat=F2}" Style="{StaticResource MetricValue}"/>
                            <ItemsControl ItemsSource="{Binding Report.MaxDh.Ids}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="Минимум" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Text="{Binding Report.MinDh.Value, StringFormat=F2}" Style="{StaticResource MetricValue}"/>
                            <ItemsControl ItemsSource="{Binding Report.MinDh.Ids}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

        </UniformGrid>
    </Grid>
</UserControl>
