<UserControl x:Class="Osadka.Views.RawDataPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:Osadka.Converters"
             AllowDrop="True"
             DragOver="Control_DragOver"
             Drop="Control_Drop"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">

    <UserControl.Resources>
        <conv:PositiveToVisibleConverter x:Key="PositiveToVisible"/>
        <conv:ZeroToVisibleConverter     x:Key="ZeroToVisible"/>
        <conv:RelaxedDoubleConverter x:Key="RelaxedDouble"/>
        <Style x:Key="RightAlign" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ToolBar VerticalAlignment="Top" Background="#F9FBFD" BorderThickness="0,0,0,1" BorderBrush="#D7D7D7">
            <Button Content="🗂 Подключить книгу" Command="{Binding LoadFromWorkbookCommand}"/>
            <Separator/>
            <Button Content="Вставить (Ctrl+V)" Command="{Binding PasteCommand}"/>
            <Separator/>
            <Button Content="🗑 Очистить" Command="{Binding ClearCommand}"/>
        </ToolBar>

        <Grid Margin="0,70,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="364*"/>
                <ColumnDefinition Width="95*"/>
                <ColumnDefinition Width="441*"/>
            </Grid.ColumnDefinitions>

            <DataGrid AutoGenerateColumns="False"
          ItemsSource="{Binding DataRows}">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Отметка, м"
                            Binding="{Binding MarkDisplay}"/>

                    <DataGridTextColumn Header="Осадка, мм"
                            Binding="{Binding SettlDisplay}"/>

                    <DataGridTextColumn Header="Общая, мм"
                            Binding="{Binding TotalDisplay}"/>

                    <DataGridTextColumn Header="№ марки"
                            Binding="{Binding Id}"/>

                </DataGrid.Columns>
            </DataGrid>

            <DataGrid Grid.Column="2" ItemsSource="{Binding CoordRows}" AutoGenerateColumns="False"
                      CanUserAddRows="False" RowHeight="28" HeadersVisibility="Column"
                      Visibility="{Binding CoordRows.Count, Converter={StaticResource PositiveToVisible}}" Margin="191,0,0,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="X" MinWidth="100" Binding="{Binding X}" ElementStyle="{StaticResource RightAlign}"/>
                    <DataGridTextColumn Header="Y" MinWidth="100" Binding="{Binding Y}" ElementStyle="{StaticResource RightAlign}"/>
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock Grid.ColumnSpan="2" Text="Вставьте данные или координаты (Ctrl+V)"
                       FontSize="18" Foreground="#999" FontStyle="Italic"
                       HorizontalAlignment="Left" VerticalAlignment="Center"
                       Visibility="{Binding ShowPlaceholder, Converter={StaticResource PositiveToVisible}}" Grid.Column="1" Height="24" Width="366"/>
        </Grid>
        <StackPanel Orientation="Horizontal" Margin="12,28,0,535">

            <StackPanel Width="110" Margin="0,0,12,0">
                <TextBlock Text="Объект №"/>
                <ComboBox Width="60"
          ItemsSource="{Binding ObjectNumbers}"
          SelectedItem="{Binding Header.ObjectNumber, Mode=TwoWay}"
          Margin="0,0,12,0"/>
            </StackPanel>


            <StackPanel Width="110" Margin="0,0,12,0">
                <TextBlock Text="Цикл №"/>
                <ComboBox Width="60"
          ItemsSource="{Binding CycleNumbers}"
          SelectedItem="{Binding Header.CycleNumber, Mode=TwoWay}"/>
            </StackPanel>
            <StackPanel Width="120" Margin="0,0,12,0">
                <TextBlock Text="Предельная, СП"/>
                <TextBox Width="80"
                 Text="{Binding Header.MaxNomen, Mode=TwoWay,Converter={StaticResource RelaxedDouble}, UpdateSourceTrigger=LostFocus}"/>
            </StackPanel>

            <StackPanel Width="123" Margin="0,0,12,0">
                <TextBlock Text="Предельная, расчёт"/>
                <TextBox Width="80"
                 Text="{Binding Header.MaxCalculated, Mode=TwoWay,Converter={StaticResource RelaxedDouble}, UpdateSourceTrigger=LostFocus}"/>
            </StackPanel>

            <StackPanel Width="135" Margin="0,0,12,0">
                <TextBlock Text="Отн. предельная, СП"/>
                <TextBox Width="80"
                 Text="{Binding Header.RelNomen, Mode=TwoWay,Converter={StaticResource RelaxedDouble}, UpdateSourceTrigger=LostFocus}"/>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Отн. предельная, расчёт"/>
                <TextBox Width="80"
                 Text="{Binding Header.RelCalculated, Mode=TwoWay,Converter={StaticResource RelaxedDouble}, UpdateSourceTrigger=LostFocus}"/>
            </StackPanel>
        </StackPanel>


    </Grid>

    <UserControl.InputBindings>
        <KeyBinding Key="V"
                Modifiers="Control"
                Command="{Binding PasteCommand}" />
    </UserControl.InputBindings>

</UserControl>
